POSTGRES_PASSWORD=
DATABASE_URL=

PORT=8100
HOST=0.0.0.0
LOG_LEVEL=info

# SmartThings의 공개 사용 서면 확인 전에는 private_beta만 사용합니다.
SERVICE_ACCESS_MODE=private_beta
# [{"username":"tester-1","passwordHash":"64자리 소문자 SHA-256"}]
PRIVATE_BETA_INVITES_JSON=

# SERVICE_ACCESS_MODE=public일 때만 아래 값을 모두 채웁니다.
PUBLIC_OPERATOR_NAME=
PUBLIC_SUPPORT_EMAIL=
PUBLIC_PRIVACY_POLICY_URL=
PUBLIC_TERMS_URL=
SMARTTHINGS_PUBLIC_USE_APPROVAL_REFERENCE=
SMARTTHINGS_PUBLIC_USE_APPROVED_AT=

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://smartthings.growful.click/oauth/callback
SMARTTHINGS_API_URL=https://api.smartthings.com
SMARTTHINGS_API_TIMEOUT_SECONDS=15
SMARTTHINGS_APP_ID=

# CLI로 만든 기존 OAuth-In 앱에 맞춘 엔드포인트입니다.
# Developer Center에서 새 Service Integration을 만들면 두 경로에 /v1을 추가합니다.
SMARTTHINGS_AUTHORIZE_URL=https://api.smartthings.com/oauth/authorize
SMARTTHINGS_TOKEN_URL=https://api.smartthings.com/oauth/token

# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

REFRESH_BEFORE_EXPIRY_SECONDS=3600
REFRESH_CHECK_INTERVAL_SECONDS=300
REFRESH_LEASE_SECONDS=120
