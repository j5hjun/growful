POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://gateway:replace-with-a-long-random-password@postgres:5432/smartthings_gateway

PORT=8100
HOST=0.0.0.0
LOG_LEVEL=info

OAUTH_ADMIN_TOKEN=replace-with-a-long-random-operator-token
OAUTH_CLIENT_ID=replace-with-smartthings-client-id
OAUTH_CLIENT_SECRET=replace-with-smartthings-client-secret
OAUTH_REDIRECT_URI=https://smartthings.growful.click/oauth/callback
SMARTTHINGS_SCOPES=r:locations:* r:devices:$ r:devices:*

# CLI로 만든 기존 OAuth-In 앱에 맞춘 엔드포인트입니다.
# Developer Center에서 새 Service Integration을 만들면 두 경로에 /v1을 추가합니다.
SMARTTHINGS_AUTHORIZE_URL=https://api.smartthings.com/oauth/authorize
SMARTTHINGS_TOKEN_URL=https://api.smartthings.com/oauth/token

# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

REFRESH_BEFORE_EXPIRY_SECONDS=3600
REFRESH_CHECK_INTERVAL_SECONDS=300
REFRESH_LEASE_SECONDS=60
