{
  "name": "@growful/smartthings-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "dev": "tsx watch src/main.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "migrate": "node dist/migrate.js",
    "start": "node dist/main.js",
    "test": "vitest run --exclude tests/postgres-oauth-store.integration.test.ts --exclude tests/oauth-state-retention.integration.test.ts",
    "test:integration": "vitest run --no-file-parallelism tests/postgres-oauth-store.integration.test.ts tests/oauth-state-retention.integration.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.10.0",
    "ky": "^2.0.2",
    "kysely": "^0.29.4",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
